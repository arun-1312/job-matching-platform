import React, { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
    LayoutDashboard, Search, Briefcase, User, FileText, BarChart2, 
    ClipboardCheck, Bookmark, MessageSquare, Settings, LogOut, 
    Bell, HelpCircle, Eye, Send
} from 'lucide-react';
// --- CORRECTED PATHS ---
import '../../styles/DashboardPage.css';
import ProfilePage from './ProfilePage';
import ResumeManagerPage from './ResumeManagerPage';
import InterviewPrepPage from './InterviewPrepPage';
import FindJobsPage from './FindJobsPage';
import MyApplicationsPage from './MyApplicationsPage';
import SkillAnalyticsPage from './SkillAnalyticsPage';
import DashboardWidgets from './DashboardWidgets';
import SavedJobsPage from './SavedJobsPage';
import MessagesPage from './MessagesPage';

// --- Reusable Sub-Components ---
const NavLink = ({ icon, text, active, isSidebarExpanded, onClick }) => (
    <button onClick={onClick} className={`w-full flex items-center px-3 py-2 text-sm font-medium rounded-md transition-colors ${active ? 'bg-slate-700 text-white' : 'text-gray-300 hover:bg-slate-700 hover:text-white'}`}>
        {icon}
        <AnimatePresence>
            {isSidebarExpanded && (
                <motion.span 
                    initial={{ opacity: 0, width: 0 }}
                    animate={{ opacity: 1, width: 'auto', transition: { delay: 0.15, duration: 0.2 } }}
                    exit={{ opacity: 0, width: 0 }}
                    className="ml-3 whitespace-nowrap"
                >
                    {text}
                </motion.span>
            )}
        </AnimatePresence>
    </button>
);

const TooltipButton = ({ children, tooltipText, onClick = () => {} }) => (
    <div className="relative group">
        <button onClick={onClick} className="p-2 rounded-full hover:bg-slate-700">
            {children}
        </button>
        <div className="absolute top-full mt-2 left-1/2 -translate-x-1/2 px-2 py-1 bg-slate-900 text-white text-xs rounded-md opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
            {tooltipText}
        </div>
    </div>
);

const NotificationsPanel = ({ isOpen }) => (
    <AnimatePresence>
        {isOpen && (
            <motion.div
                initial={{ opacity: 0, y: -10 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, y: -10 }}
                className="absolute top-16 right-6 w-80 bg-white rounded-lg shadow-2xl border border-gray-200 z-50"
            >
                <div className="p-4 border-b">
                    <h3 className="font-bold text-gray-800">Notifications</h3>
                </div>
                <div className="py-2 max-h-96 overflow-y-auto">
                    <a href="#" className="flex items-start px-4 py-3 hover:bg-slate-50">
                        <div className="w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center mr-3 flex-shrink-0"><Search size={16} className="text-teal-600" /></div>
                        <div>
                            <p className="text-sm font-semibold text-gray-800">New Job Match!</p>
                            <p className="text-xs text-gray-500">A new 'Senior Frontend Developer' role matches your profile.</p>
                        </div>
                    </a>
                </div>
            </motion.div>
        )}
    </AnimatePresence>
);

// --- Main Dashboard Component ---
const DashboardPage = ({ user, token, onLogout, onProfileUpdate }) => {
    const [isSidebarExpanded, setIsSidebarExpanded] = useState(false);
    const [activePage, setActivePage] = useState('dashboard');
    const [isNotificationsOpen, setIsNotificationsOpen] = useState(false);
    const [isActivelySeeking, setIsActivelySeeking] = useState(true);

    const renderActivePage = () => {
        switch (activePage) {
            case 'profile':
                return <ProfilePage user={user} token={token} onProfileUpdate={onProfileUpdate} />;
            case 'resumes':
                return <ResumeManagerPage token={token} />;
            case 'prep':
                return <InterviewPrepPage user={user} />;
            case 'find-jobs':
                return <FindJobsPage />;
            case 'applications':
                return <MyApplicationsPage />;
            case 'analytics':
                return <SkillAnalyticsPage />;
            case 'saved-jobs':
                return <SavedJobsPage />;
            case 'messages':
                return <MessagesPage />;
            case 'dashboard':
            default:
                return <DashboardWidgets user={user} setActivePage={setActivePage} />;
        }
    };

    return (
        <div className="flex h-screen bg-slate-100 font-sans">
            <aside 
                onMouseEnter={() => setIsSidebarExpanded(true)}
                onMouseLeave={() => setIsSidebarExpanded(false)}
                className="sidebar flex-shrink-0 bg-slate-800 text-gray-300 flex flex-col"
            >
                <div className="h-16 flex items-center justify-between px-4 border-b border-slate-700">
                    <div className="flex items-center space-x-3 overflow-hidden">
                        <div className="w-8 h-8 bg-teal-500 rounded-full flex items-center justify-center font-bold text-white flex-shrink-0">{user?.name?.charAt(0) || 'U'}</div>
                        {isSidebarExpanded && (
                            <div className="sidebar-link-text">
                                <p className="font-bold text-sm text-white whitespace-nowrap">{user?.name || 'User'}</p>
                                <div className="flex items-center space-x-2 mt-1">
                                    <span className={`text-xs ${isActivelySeeking ? 'text-green-400' : 'text-yellow-400'}`}>{isActivelySeeking ? 'Actively Seeking' : 'Paused'}</span>
                                    <button onClick={() => setIsActivelySeeking(!isActivelySeeking)} className={`w-8 h-4 rounded-full flex items-center transition-colors ${isActivelySeeking ? 'bg-green-500' : 'bg-gray-600'}`}>
                                        <span className={`block w-3 h-3 rounded-full bg-white transform transition-transform ${isActivelySeeking ? 'translate-x-4' : 'translate-x-1'}`}></span>
                                    </button>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
                <nav className="flex-1 px-3 py-4 space-y-4 overflow-y-auto overflow-x-hidden custom-scrollbar">
                    <div>
                        <h3 className={`px-2 text-xs font-semibold text-gray-500 uppercase tracking-wider ${!isSidebarExpanded && 'text-center'}`}>Core Tools</h3>
                        <div className="mt-2 space-y-1">
                            <NavLink icon={<LayoutDashboard size={20} />} text="Dashboard" active={activePage === 'dashboard'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('dashboard')} />
                            <NavLink icon={<Search size={20} />} text="Find Jobs" active={activePage === 'find-jobs'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('find-jobs')} />
                            <NavLink icon={<Briefcase size={20} />} text="My Applications" active={activePage === 'applications'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('applications')} />
                        </div>
                    </div>
                    <div>
                        <h3 className={`px-2 text-xs font-semibold text-gray-500 uppercase tracking-wider ${!isSidebarExpanded && 'text-center'}`}>Career Growth</h3>
                        <div className="mt-2 space-y-1">
                            <NavLink icon={<User size={20} />} text="My Profile" active={activePage === 'profile'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('profile')} />
                            <NavLink icon={<FileText size={20} />} text="Resume Manager" active={activePage === 'resumes'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('resumes')} />
                            <NavLink icon={<BarChart2 size={20} />} text="Skill Analytics" active={activePage === 'analytics'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('analytics')} />
                            <NavLink icon={<ClipboardCheck size={20} />} text="Interview Prep" active={activePage === 'prep'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('prep')} />
                        </div>
                    </div>
                     <div>
                        <h3 className={`px-2 text-xs font-semibold text-gray-500 uppercase tracking-wider ${!isSidebarExpanded && 'text-center'}`}>Library</h3>
                        <div className="mt-2 space-y-1">
                            <NavLink icon={<Bookmark size={20} />} text="Saved Jobs" active={activePage === 'saved-jobs'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('saved-jobs')} />
                            <NavLink icon={<MessageSquare size={20} />} text="Messages" active={activePage === 'messages'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('messages')} />
                        </div>
                    </div>
                </nav>
                <div className="px-3 py-4 border-t border-slate-700">
                    <NavLink icon={<Settings size={20} />} text="Settings" active={activePage === 'settings'} isSidebarExpanded={isSidebarExpanded} onClick={() => setActivePage('settings')} />
                </div>
            </aside>

            <div className="flex-1 flex flex-col overflow-y-auto">
                <header className="h-16 bg-slate-800 border-b border-slate-700 flex items-center justify-between px-6 flex-shrink-0 text-gray-300">
                    <div className="flex items-center space-x-2 text-sm">
                        <span className="font-semibold text-white text-lg">Zolabz AI</span>
                    </div>
                    <div className="flex items-center space-x-1">
                        <TooltipButton tooltipText="Notifications" onClick={() => setIsNotificationsOpen(!isNotificationsOpen)}>
                            <div className="relative">
                                <Bell size={20} />
                                <span className="absolute top-0 right-0 h-2 w-2 bg-red-500 rounded-full border border-slate-800"></span>
                            </div>
                        </TooltipButton>
                        <TooltipButton tooltipText="Help"><HelpCircle size={20} /></TooltipButton>
                        <TooltipButton tooltipText="Logout" onClick={onLogout}><LogOut size={20} /></TooltipButton>
                        <TooltipButton tooltipText="Profile"><div className="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center font-bold text-sm text-gray-600">{user?.name?.charAt(0) || 'U'}</div></TooltipButton>
                    </div>
                </header>
                
                <div className="relative flex-1">
                    {renderActivePage()}
                    <NotificationsPanel isOpen={isNotificationsOpen} />
                </div>
            </div>
        </div>
    );
};

export default DashboardPage;
